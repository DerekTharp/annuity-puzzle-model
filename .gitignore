# Raw HRS data (restricted-use, large files)
# Use glob form (data/raw/*) instead of bare directory (data/raw/) so the
# negation below for README.md works (git ignores file negations inside
# fully-ignored directories).
data/raw/*
!data/raw/README.md

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Julia
*.jl.cov
*.jl.*.cov
*.jl.mem
deps/build.log

# Output (regenerated by pipeline)
results/
figures/
tables/

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# Editor/IDE
*.swp
*.swo
*~
.vscode/
.idea/

# Claude Code working files
AUDIT_CONVERGENCE_REPORT.md
potential references/
scripts.zip
*.zip
